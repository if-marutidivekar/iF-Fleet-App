{
  "expo": {
    "name": "iF Fleet",
    "slug": "if-fleet",
    "version": "0.1.0",
    "scheme": "if-fleet",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.iffleet.app"
    },
    "android": {
      "package": "com.iffleet.app",
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "plugins": [
      "expo-router",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "iF Fleet needs location access to track your trip in real time."
        }
      ],
      "expo-notifications"
    ],
    "web": {
      "bundler": "metro",
      "output": "single"
    },
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "b0ce9b0e-1b23-43c7-9d7f-7253e3c54e91"
      }
    },
    "owner": "iftechnologies"
  }
}

# ─── DO NOT COMMIT REAL VALUES ─────────────────────────────────────────────────
# Copy this file to .env.staging and fill in secrets before deploying.
# .env.staging is in .gitignore and must never be committed.

# ─── Image Registry ────────────────────────────────────────────────────────────
REGISTRY=registry.internal
IMAGE_TAG=0.1.0

# ─── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_DB=fleet_db
POSTGRES_USER=fleet_user
POSTGRES_PASSWORD=CHANGE_ME

DATABASE_URL=postgresql://fleet_user:CHANGE_ME@postgres:5432/fleet_db

# ─── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ─── API ───────────────────────────────────────────────────────────────────────
NODE_ENV=staging
PORT=3001
CORS_ORIGINS=https://staging-fleet-web.internal

# ─── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET=CHANGE_ME_TO_LONG_RANDOM_STRING
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=30d
COMPANY_EMAIL_DOMAIN=company.com

# ─── Email / OTP ───────────────────────────────────────────────────────────────
SMTP_HOST=smtp.company.com
SMTP_PORT=587
SMTP_USER=fleet-noreply@company.com
SMTP_PASS=CHANGE_ME
SMTP_FROM="iF Fleet <fleet-noreply@company.com>"

# ─── Push Notifications (staging-specific credentials) ─────────────────────────
FCM_SERVER_KEY=CHANGE_ME
APNS_KEY_ID=CHANGE_ME
APNS_TEAM_ID=CHANGE_ME

# ─── Maps ──────────────────────────────────────────────────────────────────────
MAPBOX_ACCESS_TOKEN=CHANGE_ME

# ─── MinIO (object storage) ────────────────────────────────────────────────────
MINIO_ROOT_USER=fleet_admin
MINIO_ROOT_PASSWORD=CHANGE_ME

# ─── Grafana ───────────────────────────────────────────────────────────────────
GRAFANA_ADMIN_PASSWORD=CHANGE_ME

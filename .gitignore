# Dependencies
node_modules/
.pnpm-store/

# Build outputs
dist/
build/
.next/
out/

# Compiled TypeScript output in source directories (run tsc/build instead)
packages/*/src/*.js
packages/*/src/*.js.map
packages/*/src/*.d.ts
packages/*/src/*.d.ts.map
apps/api/prisma/*.js
apps/api/prisma/*.js.map
apps/api/prisma/*.d.ts
apps/api/prisma/*.d.ts.map

# Environment secrets — NEVER commit these
.env
.env.local
.env.staging
.env.production
.env.*.local

# Turbo cache
.turbo/

# Logs
*.log
npm-debug.log*
pnpm-debug.log*

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
*.swp
*.swo

# Prisma
prisma/migrations/.migration-lock

# React Native / Expo
apps/mobile/.expo/
apps/mobile/android/
apps/mobile/ios/
apps/mobile/*.jks
apps/mobile/*.keystore
# Root-level app.json auto-created by expo-cli (EAS config lives in apps/mobile/app.json)
/app.json

# Docker
infra/docker/.env.staging
